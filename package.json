{
  "name": "hl-level-monitor",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun test packages/core/core.test.ts",
    "monitor": "bun run free-port && bun run packages/monitor/index.ts",
    "free-port": "lsof -ti tcp:8787 | xargs -r kill -9 2>/dev/null; sleep 0.3; true",
    "web": "bash scripts/dev-web.sh",
    "check": "bun test packages/core/core.test.ts && bunx tsc --noEmit"
  },
  "workspaces": [
    "packages/web"
  ],
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.6.3"
  }
}
